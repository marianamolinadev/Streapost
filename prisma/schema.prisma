generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id       Int    @id
  name     String
  username String
  email    String
  phone    String?
  website  String?
  company  String?
  city     String?
  posts    Post[]
}

model Post {
  id     Int    @id
  userId Int
  title  String
  body   String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}
